{
  "name": "app-proveedores",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/index.ts",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:backup": "tsx server/scripts/backup.ts",
    "db:postgres:migrate": "tsx server/scripts/postgres-migrate.ts",
    "db:postgres:backup": "tsx server/scripts/postgres-backup.ts",
    "db:postgres:smoke": "tsx server/scripts/postgres-runtime-smoke.ts",
    "firebase:seed": "tsx scripts/seed-firebase.ts",
    "firebase:emulators": "firebase emulators:start --import=./data/firebase-emulator --export-on-exit=./data/firebase-emulator",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage:rules",
    "prod:doctor": "tsx server/scripts/production-doctor.ts",
    "prod:doctor:live": "tsx server/scripts/production-doctor.ts --live",
    "start": "NODE_ENV=production tsx server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:load": "tsx server/scripts/load-smoke.ts",
    "lint": "eslint . --ext ts,tsx --max-warnings 0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cloudinary": "^2.10.0",
    "concurrently": "^9.1.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "firebase": "^12.13.0",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "lucide-react": "^0.468.0",
    "mapbox-gl": "^3.22.0",
    "nanoid": "^5.0.9",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "firebase-admin": "^13.10.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.0.6",
    "vitest": "^4.1.5"
  }
}
