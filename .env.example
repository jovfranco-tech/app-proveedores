APP_ORIGIN=http://localhost:5173
API_PORT=5174
DATA_DIR=./data
SQLITE_PATH=./data/conectapro.sqlite
DB_DRIVER=sqlite
POSTGRES_URL=postgres://conectapro:conectapro@localhost:5432/conectapro
POSTGRES_SSL=false
POSTGRES_POOL_MAX=10

# Cambia estos secretos antes de publicar.
JWT_SECRET=change-me-access-secret-min-32-chars
REFRESH_SECRET=change-me-refresh-secret-min-32-chars
DEMO_PASSWORD=Demo123!

# Pagos: local | stripe | mercadopago
PAYMENT_PROVIDER=local
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_PRICE_ID=
MERCADOPAGO_ACCESS_TOKEN=
PUBLIC_WEBHOOK_BASE_URL=

# Mapa real. Si falta, la UI usa el mapa visual de fallback.
VITE_MAPBOX_TOKEN=

# Firebase web config publica. Estas variables pueden vivir en Vercel porque no son credenciales privilegiadas.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=chambeale-708cb
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FUNCTIONS_BASE_URL=

# Emuladores Firebase para desarrollo local. Usalos con `npm run firebase:emulators`.
VITE_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
VITE_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
VITE_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Solo backend/scripts. Nunca poner estos valores en Vite/frontend.
FIREBASE_PROJECT_ID=chambeale-708cb
FIREBASE_SERVICE_ACCOUNT_JSON=
MERCADOPAGO_WEBHOOK_SECRET=

# OAuth real
OAUTH_REDIRECT_BASE_URL=http://localhost:5174
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=

# Storage documental: s3 | cloudinary
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BASE_URL=
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Observabilidad
LOG_LEVEL=info
OTEL_SERVICE_NAME=app-proveedores-api
OTEL_EXPORTER_OTLP_ENDPOINT=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0.15
VITE_SENTRY_REPLAY_SAMPLE_RATE=0.02
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Produccion/staging
STAGING_URL=
CUSTOM_DOMAIN=
LOAD_TEST_BASE_URL=http://127.0.0.1:5174
LOAD_TEST_CONCURRENCY=10
LOAD_TEST_ROUNDS=3
